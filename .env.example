# Control plane
HOST=0.0.0.0
PORT=3000
PUBLIC_BASE_URL=https://mcc.dzxyim.top
ADMIN_TOKEN=replace-with-a-long-random-admin-token
USER_TOKEN=replace-with-a-long-random-user-token
# CONTROL_TOKEN is kept as a backward-compatible admin token alias.
CONTROL_TOKEN=replace-with-a-long-random-admin-token
RUNTIME_TOKEN=replace-with-a-second-random-token
DATA_DIR=./data

# Aliyun credentials and network
ALIYUN_ACCESS_KEY_ID=your-ak
ALIYUN_ACCESS_KEY_SECRET=your-secret
ALIYUN_REGION_ID=cn-hangzhou
ALIYUN_ZONE_ID=cn-hangzhou-i
ALIYUN_VSWITCH_ID=vsw-xxxxxxxx
ALIYUN_SECURITY_GROUP_ID=sg-xxxxxxxx
ALIYUN_EIP_INSTANCE_ID=eip-xxxxxxxx
ALIYUN_EIP_ADDRESS=X.Y.Z.W
ALIYUN_TAGS=app:minecraft-ondemand,owner:friends

# Runtime selection
RUNTIME_PROVIDER=eci
RUNTIME_NAME_PREFIX=mc-ondemand
RUNTIME_CPU=16
RUNTIME_MEMORY_GIB=28
RUNTIME_IMAGE=registry.cn-hangzhou.aliyuncs.com/your-namespace/mc-runtime:latest
RUNTIME_COMMAND=/entrypoint.sh
MINECRAFT_PORT=25565
MINECRAFT_RCON_HOST=X.Y.Z.W
MINECRAFT_RCON_PORT=25575
MINECRAFT_RCON_PASSWORD=replace-with-rcon-password
MONITOR_INTERVAL_MS=30000
MONITOR_DEBUG=false
PROM_PUSHGATEWAY_URL=
PROM_PUSH_INTERVAL_MS=10000
PROM_JOB=minecraft
PROM_SERVER_LABEL=mc
STOP_GRACE_SECONDS=90
LOCAL_STOP_EXIT_GRACE_SECONDS=60
IDLE_ALERT_MINUTES=5
IDLE_STOP_MINUTES=10
IDLE_AUTO_STOP=true
AUDIT_FILE=./audit.log

# Storage: cloud-disk for ECI, nas for NAS-backed runtime.
STORAGE_MODE=cloud-disk
STORAGE_MOUNT_PATH=/data
ALIYUN_DISK_ID=d-xxxxxxxx
STORAGE_DISK_HAS_PARTITION=false
ALLOW_ECI_PARTITIONED_DISK=false
# Optional escape hatch if Aliyun changes/needs custom FlexVolume options.
# ALIYUN_ECI_FLEX_OPTIONS_JSON={"volumeId":"d-xxxxxxxx","deleteWithInstance":"false"}

# ECS fallback when the existing disk cannot be mounted by ECI.
ECS_FALLBACK_ENABLED=false
ECS_IMAGE_ID=m-xxxxxxxx
ECS_INSTANCE_TYPE=ecs.g8i.2xlarge
ECS_SYSTEM_DISK_CATEGORY=cloud_essd
ECS_SYSTEM_DISK_SIZE_GIB=40
ECS_KEY_PAIR_NAME=

# Alerts
ALERT_EMAIL_ENABLED=false
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL_FROM=mc@example.com
ALERT_EMAIL_TO=admin@example.com
ALERT_WEBHOOK_URL=
